    <item>
      <title>HackerRank Problem 4</title>
      <link>http://localhost:1313/programming/2026/hacker-rank/problem04/</link>
      <pubDate>Wed, 11 Mar 2026 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/programming/2026/hacker-rank/problem04/</guid>
      <description>&lt;section class=&#34;section-toc&#34;&gt;&#xA;&lt;aside class=&#34;toc-sidebar-right&#34;&gt;&#xA;  &lt;div class=&#34;toc-right&#34;&gt;&#xA;    &lt;div class=&#34;toc-title&#34;&gt;Table of Contents&lt;/div&gt;&#xA;    &lt;nav&gt;&#xA;      &lt;ul&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#problem&#34;&gt;Problem&lt;/a&gt;&lt;/li&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#source-code&#34;&gt;Source Code&lt;/a&gt;&lt;/li&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#demonstration&#34;&gt;Demonstration&lt;/a&gt;&lt;/li&gt;&#xA;      &lt;/ul&gt;&#xA;    &lt;/nav&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/aside&gt;  &#xA;&#xA;&#xA;&lt;div class=&#34;page-content&#34;&gt;&#xA;&lt;h2 id=&#34;problem&#34;&gt;Problem: Conditional Statements&lt;/h2&gt;&#xA;&lt;p&gt;Link to the Challenge:&lt;/p&gt;&#xA;&lt;a href=&#34;https://www.hackerrank.com/challenges/c-tutorial-conditional-if-else/problem&#34;&gt;&#xA;Problem Statement&lt;/a&gt;&#xA;&#xA;&#xA;&lt;h2 id=&#34;source-code&#34;&gt;Source Code&lt;/h2&gt;&#xA;&lt;pre&gt;&lt;code class=&#34;language-cpp&#34;&gt;#include &amp;lt;iostream&amp;gt;&#xA;using namespace std;&#xA;&#xA;int input;&#xA;&#xA;int main() {&#xA;    cin &amp;gt;&amp;gt; input;&#xA;&#xA;    if (input == 1) {&#xA;        cout &amp;lt;&amp;lt; &#34;one&#34;;&#xA;    } else if (input == 2) {&#xA;        cout &amp;lt;&amp;lt; &#34;two&#34;;&#xA;    } else if (input == 3) {&#xA;        cout &amp;lt;&amp;lt; &#34;three&#34;;&#xA;    } else if (input == 4) {&#xA;        cout &amp;lt;&amp;lt; &#34;four&#34;;&#xA;    } else if (input == 5) {&#xA;        cout &amp;lt;&amp;lt; &#34;five&#34;;&#xA;    } else if (input == 6) {&#xA;        cout &amp;lt;&amp;lt; &#34;six&#34;;&#xA;    } else if (input == 7) {&#xA;        cout &amp;lt;&amp;lt; &#34;seven&#34;;&#xA;    } else if (input == 8) {&#xA;        cout &amp;lt;&amp;lt; &#34;eight&#34;;&#xA;    } else if (input == 9) {&#xA;        cout &amp;lt;&amp;lt; &#34;nine&#34;;&#xA;    } else {&#xA;        cout &amp;lt;&amp;lt; &#34;Greater than 9&#34;;&#xA;    }&#xA;&#xA;    return 0;&#xA;}&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&#xA;&lt;h2 id=&#34;demonstration&#34;&gt;Demonstration&lt;/h2&gt;&#xA;&lt;pre&gt;&lt;code class=&#34;bash&#34;&gt;8&#xA;eight&#xA;&#xA;44&#xA;Greater than 9&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;/section&gt;</description>
    </item>
    <item>
      <title>HackerRank Problem 5</title>
      <link>http://localhost:1313/programming/2026/hacker-rank/problem05/</link>
      <pubDate>Wed, 11 Mar 2026 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/programming/2026/hacker-rank/problem05/</guid>
      <description>&lt;section class=&#34;section-toc&#34;&gt;&#xA;&lt;aside class=&#34;toc-sidebar-right&#34;&gt;&#xA;  &lt;div class=&#34;toc-right&#34;&gt;&#xA;    &lt;div class=&#34;toc-title&#34;&gt;Table of Contents&lt;/div&gt;&#xA;    &lt;nav&gt;&#xA;      &lt;ul&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#problem&#34;&gt;Problem&lt;/a&gt;&lt;/li&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#source-code&#34;&gt;Source Code&lt;/a&gt;&lt;/li&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#demonstration&#34;&gt;Demonstration&lt;/a&gt;&lt;/li&gt;&#xA;      &lt;/ul&gt;&#xA;    &lt;/nav&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/aside&gt;  &#xA;&#xA;&#xA;&lt;div class=&#34;page-content&#34;&gt;&#xA;&lt;h2 id=&#34;problem&#34;&gt;Problem: For Loop&lt;/h2&gt;&#xA;&lt;p&gt;Link to the Challenge:&lt;/p&gt;&#xA;&lt;a href=&#34;https://www.hackerrank.com/challenges/c-tutorial-for-loop/problem&#34;&gt;&#xA;Problem Statement&lt;/a&gt;&#xA;&#xA;&#xA;&lt;h2 id=&#34;source-code&#34;&gt;Source Code&lt;/h2&gt;&#xA;&lt;pre&gt;&lt;code class=&#34;language-cpp&#34;&gt;#include &amp;lt;iostream&amp;gt;&#xA;using namespace std;&#xA;&#xA;int a;&#xA;int b;&#xA;int n;&#xA;&#xA;int main() {&#xA;    cin &amp;gt;&amp;gt; a &amp;gt;&amp;gt; b;&#xA;&#xA;    for (int i = a; i &amp;lt;= b; i++) {&#xA;        if (i == 1) {&#xA;            cout &amp;lt;&amp;lt; &#34;one&#34; &amp;lt;&amp;lt; endl;&#xA;        } else if (i == 2) {&#xA;            cout &amp;lt;&amp;lt; &#34;two&#34; &amp;lt;&amp;lt; endl;&#xA;        } else if (i == 3) {&#xA;            cout &amp;lt;&amp;lt; &#34;three&#34; &amp;lt;&amp;lt; endl;&#xA;        } else if (i == 4) {&#xA;            cout &amp;lt;&amp;lt; &#34;four&#34; &amp;lt;&amp;lt; endl;&#xA;        } else if (i == 5) {&#xA;            cout &amp;lt;&amp;lt; &#34;five&#34; &amp;lt;&amp;lt; endl;&#xA;        } else if (i == 6) {&#xA;            cout &amp;lt;&amp;lt; &#34;six&#34; &amp;lt;&amp;lt; endl;&#xA;        } else if (i == 7) {&#xA;            cout &amp;lt;&amp;lt; &#34;seven&#34; &amp;lt;&amp;lt; endl;&#xA;        } else if (i == 8) {&#xA;            cout &amp;lt;&amp;lt; &#34;eight&#34; &amp;lt;&amp;lt; endl;&#xA;        } else if (i == 9) {&#xA;            cout &amp;lt;&amp;lt; &#34;nine&#34; &amp;lt;&amp;lt; endl;&#xA;        } else if (i % 2 == 0) {&#xA;            cout &amp;lt;&amp;lt; &#34;even&#34; &amp;lt;&amp;lt; endl;&#xA;        } else {&#xA;            cout &amp;lt;&amp;lt; &#34;odd&#34; &amp;lt;&amp;lt; endl;&#xA;        }&#xA;    }&#xA;&#xA;    return 0;&#xA;}&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&#xA;&lt;h2 id=&#34;demonstration&#34;&gt;Demonstration&lt;/h2&gt;&#xA;&lt;pre&gt;&lt;code class=&#34;bash&#34;&gt;8&#xA;11&#xA;eight&#xA;nine&#xA;even&#xA;odd&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;/section&gt;</description>
    </item>
    <item>
      <title>HackerRank Problem 6</title>
      <link>http://localhost:1313/programming/2026/hacker-rank/problem06/</link>
      <pubDate>Wed, 11 Mar 2026 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/programming/2026/hacker-rank/problem06/</guid>
      <description>&lt;section class=&#34;section-toc&#34;&gt;&#xA;&lt;aside class=&#34;toc-sidebar-right&#34;&gt;&#xA;  &lt;div class=&#34;toc-right&#34;&gt;&#xA;    &lt;div class=&#34;toc-title&#34;&gt;Table of Contents&lt;/div&gt;&#xA;    &lt;nav&gt;&#xA;      &lt;ul&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#problem&#34;&gt;Problem&lt;/a&gt;&lt;/li&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#source-code&#34;&gt;Source Code&lt;/a&gt;&lt;/li&gt;&#xA;        &lt;li&gt;&lt;a href=&#34;#demonstration&#34;&gt;Demonstration&lt;/a&gt;&lt;/li&gt;&#xA;      &lt;/ul&gt;&#xA;    &lt;/nav&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/aside&gt;  &#xA;&#xA;&#xA;&lt;div class=&#34;page-content&#34;&gt;&#xA;&lt;h2 id=&#34;problem&#34;&gt;Problem: Functions&lt;/h2&gt;&#xA;&lt;p&gt;Link to the Challenge:&lt;/p&gt;&#xA;&lt;a href=&#34;https://www.hackerrank.com/challenges/c-tutorial-functions/problem&#34;&gt;&#xA;Problem Statement&lt;/a&gt;&#xA;&#xA;&#xA;&lt;h2 id=&#34;source-code&#34;&gt;Source Code&lt;/h2&gt;&#xA;&lt;pre&gt;&lt;code class=&#34;language-cpp&#34;&gt;#include &amp;lt;iostream&amp;gt;&#xA;using namespace std;&#xA;&#xA;int a;&#xA;int b;&#xA;int c;&#xA;int d;&#xA;int maxValue = 0;&#xA;&#xA;void findMax() {&#xA;    cin &amp;gt;&amp;gt; a &amp;gt;&amp;gt; b &amp;gt;&amp;gt; c &amp;gt;&amp;gt; d;&#xA;&#xA;    if (a &amp;gt; maxValue) {&#xA;        maxValue = a;&#xA;    } else {&#xA;        maxValue = maxValue;&#xA;    }&#xA;&#xA;    if (b &amp;gt; maxValue) {&#xA;        maxValue = b;&#xA;    } else {&#xA;        maxValue = maxValue;&#xA;    }&#xA;&#xA;    if (c &amp;gt; maxValue) {&#xA;        maxValue = c;&#xA;    } else {&#xA;        maxValue = maxValue;&#xA;    }&#xA;&#xA;    if (d &amp;gt; maxValue) {&#xA;        maxValue = d;&#xA;    } else {&#xA;        maxValue = maxValue;&#xA;    }&#xA;}&#xA;&#xA;int main() {&#xA;    findMax();&#xA;    cout &amp;lt;&amp;lt; maxValue &amp;lt;&amp;lt; endl;&#xA;&#xA;    return 0;&#xA;}&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&#xA;&lt;h2 id=&#34;demonstration&#34;&gt;Demonstration&lt;/h2&gt;&#xA;&lt;pre&gt;&lt;code class=&#34;bash&#34;&gt;3&#xA;4&#xA;6&#xA;5&#xA;6&#xA;&lt;/code&gt;&lt;/pre&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;/section&gt;</description>
    </item>
    <item>
      <title>HackerRank Problem 7</title>
      <link>http://localhost:1313/programming/2026/hacker-rank/problem07/</link>
      <pubDate>Wed, 11 Mar 2026 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/programming/2026/hacker-rank/problem07/</guid>
